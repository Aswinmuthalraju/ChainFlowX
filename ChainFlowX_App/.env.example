# ChainFlowX — copy this to .env and fill in your values
# Single OpenAI-compatible LLM endpoint

# Base URL for an OpenAI-compatible API (Ollama, LM Studio, OpenAI-compatible proxy, etc.)
# Default local Ollama endpoint shown below.
VITE_LLM_BASE_URL=http://localhost:11434

# Optional API key for endpoints that require auth. Leave blank for local Ollama.
VITE_LLM_API_KEY=

# Classification model (fast, structured extraction)
VITE_LLM_CLASSIFY_MODEL=llama3.1:8b

# Strategic synthesis model (long-form reasoning and planning)
VITE_LLM_SYNTHESIZE_MODEL=llama3.1:8b

# Vercel API base — leave blank for local dev
VITE_API_BASE=
