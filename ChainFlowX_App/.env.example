# ChainFlowX — copy this to .env and fill in your values
# All AI models run locally via Ollama (https://ollama.com)

# Gemma 4 E4B — Layer 3 fast classification
# Run locally: ollama run gemma4:e4b
# Default Ollama port is 11434. Change only if you've remapped it.
VITE_GEMMA_URL=http://localhost:11434
VITE_GEMMA_MODEL=gemma4:e4b

# Qwen3:8B — Layer 5 strategic synthesis
# Run locally: ollama run qwen3:8b
# If running on a second machine, set to that machine's IP, e.g. http://192.168.1.x:11434
VITE_QWEN_URL=http://localhost:11434
VITE_QWEN_MODEL=qwen3:8b

# Vercel API base — leave blank for local dev
VITE_API_BASE=

# AIS live ship tracking — free key from aisstream.io
VITE_AISSTREAM_KEY=get_free_key_at_aisstream.io
